{
  "name": "@joedeleeuw/antidrift",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "description": "Deterministic lint + policy guardrails against code and AI-agent drift: a custom ESLint plugin, shareable ESLint config, and a policy generator for agent instruction files and hooks.",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslint-config",
    "lint",
    "guardrails",
    "ai",
    "agents",
    "codegen",
    "policy",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joedeleeuw/antidrift.git",
    "directory": "tooling/antidrift"
  },
  "homepage": "https://github.com/joedeleeuw/antidrift#readme",
  "bugs": "https://github.com/joedeleeuw/antidrift/issues",
  "publishConfig": {
    "access": "public"
  },
  "types": "./src/index.d.mts",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "import": "./src/index.mjs"
    },
    "./brand": {
      "types": "./src/brand/index.d.mts",
      "import": "./src/brand/index.mjs"
    },
    "./eslint-plugin": {
      "types": "./src/eslint-plugin/index.d.ts",
      "import": "./src/eslint-plugin/index.js"
    },
    "./eslint-config": {
      "types": "./src/eslint-config/index.d.mts",
      "import": "./src/eslint-config/index.mjs"
    },
    "./policy": {
      "types": "./src/policy/index.d.mts",
      "import": "./src/policy/index.mjs"
    },
    "./semantic-adapters": {
      "types": "./src/semantic-adapters/index.d.mts",
      "import": "./src/semantic-adapters/index.mjs"
    },
    "./semantic-adapters/async-control-flow": {
      "types": "./src/semantic-adapters/async-control-flow.d.mts",
      "import": "./src/semantic-adapters/async-control-flow.mjs"
    },
    "./semantic-adapters/auth-boundary": {
      "types": "./src/semantic-adapters/auth-boundary.d.mts",
      "import": "./src/semantic-adapters/auth-boundary.mjs"
    },
    "./semantic-adapters/broad-input": {
      "types": "./src/semantic-adapters/broad-input.d.mts",
      "import": "./src/semantic-adapters/broad-input.mjs"
    },
    "./semantic-adapters/parse-input": {
      "types": "./src/semantic-adapters/parse-input.d.mts",
      "import": "./src/semantic-adapters/parse-input.mjs"
    },
    "./semantic-adapters/react-state": {
      "types": "./src/semantic-adapters/react-state.d.mts",
      "import": "./src/semantic-adapters/react-state.mjs"
    },
    "./semantic-adapters/schema-provenance": {
      "types": "./src/semantic-adapters/schema-provenance.d.mts",
      "import": "./src/semantic-adapters/schema-provenance.mjs"
    },
    "./semantic-adapters/sql": {
      "types": "./src/semantic-adapters/sql.d.mts",
      "import": "./src/semantic-adapters/sql.mjs"
    },
    "./semantic-adapters/tuple-shape": {
      "types": "./src/semantic-adapters/tuple-shape.d.mts",
      "import": "./src/semantic-adapters/tuple-shape.mjs"
    },
    "./semantic-adapters/type-owner": {
      "types": "./src/semantic-adapters/type-owner.d.mts",
      "import": "./src/semantic-adapters/type-owner.mjs"
    }
  },
  "bin": {
    "antidrift": "src/policy/cli.mjs"
  },
  "files": [
    "src",
    "!src/**/*.test.*",
    "!src/**/fixtures/**"
  ],
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/utils": "^8.60.1",
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^15.14.0",
    "yaml": "^2.6.1"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": ">=8",
    "eslint": ">=9",
    "typescript": ">=5",
    "typescript-eslint": ">=8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/parser": "^8.60.1",
    "@typescript-eslint/rule-tester": "^8.60.1",
    "firebase": "^11.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
